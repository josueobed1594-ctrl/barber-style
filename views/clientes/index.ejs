<%- include('../layouts/header', { titulo: 'Barber Style' }) %>

<%- include('../layouts/navbar') %>

<!-- HERO RESPONSIVE -->
<section class="hero">

    <div class="overlay"></div>

    <div class="content">

        <h1 class="display-3 fw-bold">
            Barber Style
        </h1>

        <p class="lead mt-3">
            Cortes modernos, afeitado profesional y la mejor experiencia de barbería.
        </p>

        <a href="/reservar" class="btn btn-warning btn-lg mt-3">
            Reservar Cita
        </a>

    </div>

</section>

<!-- SECCIÓN EXTRA -->
<section class="container py-5 text-center">

    <h2 class="mb-3">Tu estilo, nuestra pasión</h2>

    <p class="text-white">
        Reserva tu cita y vive una experiencia de barbería profesional.
    </p>

</section>

<%- include('../layouts/footer') %>

<!-- ESTILOS -->
<style>

.hero {
    position: relative;
    background-image: url('/img/banner.jpg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;

    height: 80vh;

    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;

    color: white;
    padding: 20px;
}

/* overlay oscuro */
.hero .overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;

    background: rgba(0,0,0,0.5);
}

/* contenido encima */
.hero .content {
    position: relative;
    z-index: 2;
    max-width: 900px;
}

/* TABLET */
@media (max-width: 768px) {

    .hero {
        height: 60vh;
        background-position: center top;
    }

    .hero h1 {
        font-size: 2.2rem;
    }

    .hero p {
        font-size: 1rem;
                font-weight: 500;
    }

}

/* MOBILE */
@media (max-width: 480px) {

    .hero {
        height: 50vh;
        background-position: center;
    }

    .hero h1 {
        font-size: 1.6rem;
    }

    .hero p {
        font-size: 0.95rem;
    }

}

</style>