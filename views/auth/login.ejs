<%- include('../layouts/header', { titulo: 'Login | Barber Style' }) %>

<%- include('../layouts/navbar') %>

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-5">

            <div class="card shadow">

                <div class="card-body">

                    <h2 class="text-center mb-4">
                        Iniciar Sesión
                    </h2>

                    <form action="/login" method="POST">

                        <div class="mb-3">

                            <label class="form-label">
                                Email
                            </label>

                            <input
                                type="email"
                                name="email"
                                class="form-control"
                                required
                            >

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                Contraseña
                            </label>

                            <input
                                type="password"
                                name="password"
                                class="form-control"
                                required
                            >

                        </div>

                        <button
                            type="submit"
                            class="btn btn-dark w-100">

                            Ingresar

                        </button>
                        <div class="text-center mt-3">
                            <a href="/register">¿No tienes cuenta? Regístrate</a>
                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

<%- include('../layouts/footer') %>